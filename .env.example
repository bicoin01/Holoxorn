# ========================================
# HOLOXORN AI - ENVIRONMENT VARIABLES
# ========================================
# Copy this file to .env and fill in your values
# Never commit .env to GitHub!

# ========================================
# SERVER CONFIGURATION
# ========================================
PORT=3000
NODE_ENV=production
HOST=localhost

# ========================================
# API KEYS FOR AI SERVICES (Optional)
# ========================================
# OpenAI API (for advanced AI responses)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# Google AI (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude
CLAUDE_API_KEY=your_claude_api_key_here

# ========================================
# FIREBASE AUTHENTICATION (Google Login)
# ========================================
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=holoxorn.firebaseapp.com
FIREBASE_PROJECT_ID=holoxorn
FIREBASE_STORAGE_BUCKET=holoxorn.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# ========================================
# DATABASE (Optional - for production)
# ========================================
# MongoDB (alternative to JSON file)
MONGODB_URI=mongodb://localhost:27017/holoxorn

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/holoxorn

# ========================================
# STORAGE (File Uploads)
# ========================================
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,video/mp4,audio/mpeg,application/pdf
UPLOAD_DIR=./backend/uploads

# Cloud Storage (AWS S3 or similar)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=holoxorn-uploads
AWS_REGION=us-east-1

# ========================================
# EMAIL CONFIGURATION (For password reset)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@holoxornai.com

# ========================================
# SECURITY
# ========================================
JWT_SECRET=your_super_secret_jwt_key_change_this
SESSION_SECRET=your_session_secret_change_this
CORS_ORIGIN=https://www.holoxornai.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# GOOGLE OAUTH (Alternative to Firebase)
# ========================================
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ========================================
# FEATURE FLAGS
# ========================================
ENABLE_VOICE_COMMANDS=true
ENABLE_FILE_UPLOADS=true
ENABLE_AI_CHAT=true
ENABLE_ANALYTICS=true
ENABLE_OFFLINE_MODE=true

# ========================================
# LOGGING & MONITORING
# ========================================
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn_url

# ========================================
# MAINTENANCE
# ========================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=Holoxorn AI is under maintenance. Please check back soon!

# ========================================
# FRONTEND CONFIGURATION
# ========================================
FRONTEND_URL=https://www.holoxornai.com
API_URL=https://api.holoxornai.com

# ========================================
# VOICE RECOGNITION API (Optional)
# ========================================
ASSEMBLYAI_API_KEY=your_assemblyai_key
DEEPGRAM_API_KEY=your_deepgram_key

# ========================================
# PAYMENT (For premium features - future)
# ========================================
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
